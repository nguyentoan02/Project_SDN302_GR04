<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Book Store</title>
    <style>
      .tg-middlecontainer {
        padding: 20px 0;
        background: #f8f8f8;
        border-bottom: 1px solid #ddd;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 15px;
      }

      .tg-logo {
        display: block;
        text-align: center;
        margin-bottom: 20px;
      }

      .tg-logo a {
        text-decoration: none;
        font-size: 32px;
        color: #333;
        font-weight: bold;
      }

      .tg-logo span {
        display: block;
        font-size: 14px;
        color: #666;
        font-weight: normal;
      }

      .tg-middlecontent {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px; 
        flex-wrap: wrap; 
      }

      .tg-searchbox {
        flex: 1 1 300px; 
        margin: 0; 
      }

    
      .tg-wishlistandcart {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin: 0; 
        margin-right: 110px;
      }

      .tg-wishlistandcart a {
        text-decoration: none;
        display: flex;
        align-items: center;
        padding: 8px 15px; 
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 25px;
        color: #333;
        font-size: 14px; 
        transition: all 0.3s ease;
      }

      .tg-wishlistandcart a:hover {
        background: #007bff;
        color: #fff;
        border-color: #007bff;
      }

      .tg-themebadge {
        display: inline-flex;
        width: 18px; 
        height: 18px;
        background: #eb2929;
        color: #fff;
        border-radius: 50%;
        justify-content: center;
        align-items: center;
        margin-right: 6px; 
        font-size: 12px; 
      }

      #tg-wishlisst:hover .tg-themebadge {
        background: #fff;
        color: #007bff;
      }

      #tg-minicart:hover .tg-themebadge {
        background: #fff;
        color: #007bff;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .tg-middlecontent {
          flex-direction: column;
          gap: 10px;
        }

        .tg-logo a {
          font-size: 24px;
        }

        .tg-searchbox {
          flex: 1 1 100%; 
        }

        .tg-wishlistandcart {
          flex-direction: column;
          align-items: center;
          gap: 10px;
        }
      }
    </style>
  </head>
  <body>
    <!-- Include header -->
    <%- include('../partials/navbar') %>

    <!-- Thêm phần tg-middlecontainer -->
    <div class="tg-middlecontainer">
      <div class="container">
        <div class="tg-middlecontent">
          <div class="tg-searchbox">
            <%- include('../books/filter', { books, name }) %>
          </div>
          <div class="tg-wishlistandcart">
            <a href="/api/favorites" id="tg-wishlisst">
              <span class="tg-themebadge">+</span>
              <span>♥ Wishlist</span>
            </a>
            <a href="/api/cart/products" id="tg-minicart">
              <span class="tg-themebadge">+</span>
              <span>🛒 Cart</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Phần body chính, sử dụng nội dung từ index.ejs -->
    <div class="container mt-4">
      <%- include('../books/list', { books, name }) %>
    </div>

    <!-- Include footer -->
    <%- include('../partials/footerHome') %>
  </body>
</html>