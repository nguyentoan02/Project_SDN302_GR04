<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        .cart-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .cart-items {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .cart-item {
            display: grid;
            grid-template-columns: 120px 1fr auto auto;
            gap: 20px;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
            align-items: center;
        }

        .cart-item img {
            width: 120px;
            height: 160px;
            object-fit: cover;
            border-radius: 4px;
        }

        .item-details {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .item-details h3 {
            margin: 0;
            color: #333;
        }

        .price {
            font-size: 1.2em;
            color: #2c5282;
        }

        .quantity {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quantity button {
            background: #4299e1;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
        }

        .quantity button:disabled {
            background: #cbd5e0;
            cursor: not-allowed;
        }

        .quantity input {
            width: 50px;
            text-align: center;
            padding: 8px;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
        }

        .remove {
            background: #f56565;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
        }

        .cart-summary {
            margin-top: 30px;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
            transition: opacity 0.3s ease;
            opacity: 0;
        }

        .cart-summary[style*="display: block"] {
            opacity: 1;
        }

        .checkout {
            width: 100%;
            padding: 12px;
            background: #48bb78;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1.1em;
            margin-top: 20px;
        }

        .empty-cart {
            text-align: center;
            padding: 40px;
        }

        .empty-cart a {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #4299e1;
            color: white;
            text-decoration: none;
            border-radius: 4px;
        }
         
        .button-loading {
            position: relative;
            pointer-events: none;
            opacity: 0.7;
        }

        .button-loading::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            margin: auto;
            border: 4px solid transparent;
            border-top-color: #ffffff;
            border-radius: 50%;
            animation: button-loading-spinner 1s linear infinite;
        }
        .item-checkbox {
            width: 20px;
            height: 20px;
            margin-right: 10px;
        }

        .cart-item {
            grid-template-columns: auto 120px 1fr auto auto;
        }

        #checkout-btn:disabled {
            background: #cbd5e0;
            cursor: not-allowed;
        }

        @keyframes button-loading-spinner {
            from {
                transform: rotate(0turn);
            }
            to {
                transform: rotate(1turn);
            }
        }
    </style>
</head>
<body>
    <header>
        <%- include('../../partials/navbar') %>
    </header>
    <div class="cart-container">
        <h2>Shopping Cart</h2>
        
        <div class="cart-items">
            <% if (carts && carts.length > 0) { %>
                <% let total = 0 %>
                <% carts.forEach(cart => { %>
                    <% total += cart.product.price * cart.quantity %>
                    <div class="cart-item" data-id="<%= cart.product._id %>">

                        <input type="checkbox" 
                            class="item-checkbox" 
                            data-price="<%= cart.product.price %>" 
                            data-quantity="<%= cart.quantity %>"
                            data-id="<%= cart.product._id %>"
                        >

                        <img src="<%= cart.product.image || '/images/default-book.jpg' %>" 
                             alt="<%= cart.product.name %>">
                        <div class="item-details">
                            <h3><%= cart.product.name %></h3>
                            <p class="description"><%= cart.product.description %></p>
                            <p class="price">€ <%= cart.product.price.toFixed(2) %></p>
                            <div class="quantity">
                                <button class="quantity-decrease" data-product-id="<%= cart.product._id %>"
                                    <%= cart.quantity <= 1 ? 'disabled' : '' %>>
                                    -
                                </button>

                                <input type="text" value="<%= cart.quantity %>" readonly>
                                <button class="quantity-increase" data-product-id="<%= cart.product._id %>"
                                         <%= cart.quantity >= cart.product.stock ? 'disabled' : '' %>>
                                         +
                                </button>
                                <span class="stock">(<%=cart.product.stock%> available)</span>
                            </div>
                        </div>
                        <p class="item-total">€ <%= (cart.product.price * cart.quantity).toFixed(2) %></p>
                        <button class="remove" data-product-id="<%= cart.product._id %>">Remove</button>
                    </div>
                <% }) %>

                <div id="cart-summary-id" class="cart-summary" style="display: none;">
                    <h3>Order Summary</h3>
                    <p>Selected Items: <span id="selected-count">0</span></p>
                    <p>Subtotal: € <span id="subtotal">0.00</span></p>
                    <% const shippingCost = 5.00 %>
                    <p>Shipping: € <%= shippingCost.toFixed(2) %></p>
                    <h3>Total: € <span id="total">0.00</span></h3>
                    <button class="checkout" id="checkout-btn" disabled>Proceed to Checkout</button>
                </div>
            <% } else { %>
                <div class="empty-cart">
                    <h3>Your cart is empty</h3>
                    <a href="/">Continue Shopping</a>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>

<script>
    const shipping_cost = 5.0;

    document.addEventListener('DOMContentLoaded', () => {
        // Quantity decrease buttons
        document.querySelectorAll('.quantity-decrease').forEach(button => {
        button.addEventListener('click', () => {
            updateQuantity(button.dataset.productId, -1);
        });
        });

        // Quantity increase buttons
        document.querySelectorAll('.quantity-increase').forEach(button => {
        button.addEventListener('click', () => {
            updateQuantity(button.dataset.productId, 1);
        });
        });

        // Remove buttons
        document.querySelectorAll('.remove').forEach(button => {
        button.addEventListener('click', () => {
            removeItem(button.dataset.productId);
        });
        });

        // Checkout button
        const checkoutButton = document.querySelector('.checkout');
        if (checkoutButton) {
        checkoutButton.addEventListener('click', checkout);
        }
        
        // Handle checkboxes
        document.querySelectorAll('.item-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', updateTotals);
        });

        // Initial update
        updateTotals();
    });

const setLoading = (button, isLoading) => {
    if (isLoading) {
        button.classList.add('button-loading');
        button.disabled = true;
        button.textContent = '';
    } else {
        button.classList.remove('button-loading');
        button.disabled = false;
        button.textContent = button.dataset.originalText;
    }
};

const disableAllButtons = () => {
    document.querySelectorAll('button').forEach(button => {
        button.dataset.originalText = button.textContent;
        button.disabled = true;
    });
};

const enableAllButtons = () => {
    document.querySelectorAll('button').forEach(button => {
        button.disabled = false;
    });
};

async function updateQuantity(productId, change) {
    const button = event.currentTarget;
    try {
        setLoading(button, true);
        disableAllButtons();

        const response = await fetch('/api/cart/update', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                product_id: productId,
                quantity: change
            })
        });
        
        if (response.ok) {
            window.location.reload();
        } else {
            const error = await response.json();
            alert(error.message || 'Failed to update quantity');
        }
    } catch (error) {
        console.error('Error updating quantity:', error);
        alert('Failed to update quantity');
    } finally {
        setLoading(button, false);
        enableAllButtons();
    }
}

async function removeItem(productId) {
    const button = event.currentTarget;
    if (!confirm('Are you sure you want to remove this item?')) return;
    
    try {
        setLoading(button, true);
        disableAllButtons();
        
        const cartItem = button.closest('.cart-item');
        const quantityInput = cartItem.querySelector('input[type="text"]');
        const quantity = parseInt(quantityInput.value, 10);

        const response = await fetch('/api/cart/remove', {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                product_id: productId,
                quantity,
            })
        });
        
        if (response.ok) {
            window.location.reload();
        } else {
            const error = await response.json();
            alert(error.message || 'Failed to remove item');
        }
    } catch (error) {
        console.error('Error removing item:', error);
        alert('Failed to remove item');
    } finally {
        setLoading(button, false);
        enableAllButtons();
    }
}

async function checkout() {
    const button = event.currentTarget;
    try {
        setLoading(button, true);
        disableAllButtons();


        const selectedItems = Array.from(document.querySelectorAll('.item-checkbox:checked')).map(checkbox => checkbox.dataset.id);
         
        if (selectedItems.length === 0) {
            alert('Please select items to checkout');
            return;
        }

        const response = await fetch('/api/orders/create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                product_ids: selectedItems,
                payment_method: 'cash',
                shipping_cost
            })
        });
        
        if (response.ok) {
            window.location.href = '/api/orders/history';
        } else {
            const error = await response.json();
            alert(error.message || 'Failed to create order');
        }
    } catch (error) {
        console.error('Error creating order:', error);
        alert('Failed to create order');
    } finally {
        setLoading(button, false);
        enableAllButtons();
    }
}

function updateTotals() {
    const checkboxes = document.querySelectorAll('.item-checkbox:checked');
    const shippingCost = 5.00;
    const cartSummary = document.getElementById('cart-summary-id');
    
    if(checkboxes.length === 0){
        cartSummary.style.display ="none";
        return;
    }

    let subtotal = 0;
    const selectedItems = [];

    checkboxes.forEach(checkbox => {
        const price = parseFloat(checkbox.dataset.price);
        const quantity = parseInt(checkbox.dataset.quantity);
        subtotal += price * quantity;
        selectedItems.push(checkbox.dataset.id);
    });

    document.getElementById('selected-count').textContent = checkboxes.length;
    document.getElementById('subtotal').textContent = subtotal.toFixed(2);
    document.getElementById('total').textContent = (subtotal + shippingCost).toFixed(2);

    const checkoutBtn = document.getElementById('checkout-btn');
    checkoutBtn.disabled = checkboxes.length === 0;
    cartSummary.style.display = 'block';
}
</script>