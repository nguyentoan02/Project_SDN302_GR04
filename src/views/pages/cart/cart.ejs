<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        .cart-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .cart-items {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .cart-item {
            display: grid;
            grid-template-columns: 120px 1fr auto auto;
            gap: 20px;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
            align-items: center;
        }

        .cart-item img {
            width: 120px;
            height: 160px;
            object-fit: cover;
            border-radius: 4px;
        }

        .item-details {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .item-details h3 {
            margin: 0;
            color: #333;
        }

        .price {
            font-size: 1.2em;
            color: #2c5282;
        }

        .quantity {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .quantity button {
            background: #4299e1;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
        }

        .quantity button:disabled {
            background: #cbd5e0;
            cursor: not-allowed;
        }

        .quantity input {
            width: 50px;
            text-align: center;
            padding: 8px;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
        }

        .remove {
            background: #f56565;
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
        }

        .cart-summary {
            margin-top: 30px;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 8px;
        }

        .checkout {
            width: 100%;
            padding: 12px;
            background: #48bb78;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1.1em;
            margin-top: 20px;
        }

        .empty-cart {
            text-align: center;
            padding: 40px;
        }

        .empty-cart a {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #4299e1;
            color: white;
            text-decoration: none;
            border-radius: 4px;
        }
         
        .button-loading {
            position: relative;
            pointer-events: none;
            opacity: 0.7;
        }

        .button-loading::after {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            margin: auto;
            border: 4px solid transparent;
            border-top-color: #ffffff;
            border-radius: 50%;
            animation: button-loading-spinner 1s linear infinite;
        }

        @keyframes button-loading-spinner {
            from {
                transform: rotate(0turn);
            }
            to {
                transform: rotate(1turn);
            }
        }
    </style>
</head>
<body>
    <div class="cart-container">
        <h2>Shopping Cart</h2>
        
        <div class="cart-items">
            <% if (carts && carts.length > 0) { %>
                <% let total = 0 %>
                <% carts.forEach(cart => { %>
                    <% total += cart.product.price * cart.quantity %>
                    <div class="cart-item" data-id="<%= cart.product._id %>">
                        <img src="<%= cart.product.image || '/images/default-book.jpg' %>" 
                             alt="<%= cart.product.name %>">
                        <div class="item-details">
                            <h3><%= cart.product.name %></h3>
                            <p class="description"><%= cart.product.description %></p>
                            <p class="price">€ <%= cart.product.price.toFixed(2) %></p>
                            <div class="quantity">
                                <button onclick="updateQuantity('<%= cart.product._id %>', -1)" 
                                        <%= cart.quantity <= 1 ? 'disabled' : '' %>>-</button>
                                <input type="text" value="<%= cart.quantity %>" readonly>
                                <button onclick="updateQuantity('<%= cart.product._id %>', 1)"
                                        <%= cart.quantity >= cart.product.stock ? 'disabled' : '' %>>+</button>
                                <span class="stock">(<%=cart.product.stock%> available)</span>
                            </div>
                        </div>
                        <p class="item-total">€ <%= (cart.product.price * cart.quantity).toFixed(2) %></p>
                        <button class="remove" onclick="removeItem('<%= cart.product._id %>')">Remove</button>
                    </div>
                <% }) %>

                <div class="cart-summary">
                    <h3>Order Summary</h3>
                    <p>Subtotal: € <%= total.toFixed(2) %></p>
                    <% const shippingCost = 5.00 %>
                    <p>Shipping: € <%= shippingCost.toFixed(2) %></p>
                    <h3>Total: € <%= (total + shippingCost).toFixed(2) %></h3>
                    <button class="checkout" onclick="checkout()">Proceed to Checkout</button>
                </div>
            <% } else { %>
                <div class="empty-cart">
                    <h3>Your cart is empty</h3>
                    <a href="/books">Continue Shopping</a>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        const setLoading = (button, isLoading) => {
            if (isLoading) {
                button.classList.add('button-loading');
                button.disabled = true;
                button.textContent = '';
            } else {
                button.classList.remove('button-loading');
                button.disabled = false;
                button.textContent = button.dataset.originalText;
            }
        };

        const disableAllButtons = () => {
            document.querySelectorAll('button').forEach(button => {
                button.dataset.originalText = button.textContent;
                button.disabled = true;
            });
        };

        const enableAllButtons = () => {
            document.querySelectorAll('button').forEach(button => {
                button.disabled = false;
            });
        };

        async function updateQuantity(productId, change) {
            const button = event.currentTarget;
            try {
                // setLoading(button, true);
                // disableAllButtons();

                const response = await fetch('/api/cart/update', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        product_id: productId,
                        quantity: change
                    })
                });
                
                if (response.ok) {
                    window.location.reload();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Failed to update quantity');
                }
            } catch (error) {
                console.error('Error updating quantity:', error);
                alert('Failed to update quantity');
            } finally {
                // setLoading(button, false);
                // enableAllButtons();
            }
        }

        async function removeItem(productId) {
            const button = event.currentTarget;
            if (!confirm('Are you sure you want to remove this item?')) return;
            
            try {
                setLoading(button, true);
                disableAllButtons();

                const response = await fetch('/api/cart/remove', {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        product_id: productId
                    })
                });
                
                if (response.ok) {
                    window.location.reload();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Failed to remove item');
                }
            } catch (error) {
                console.error('Error removing item:', error);
                alert('Failed to remove item');
            } finally {
                setLoading(button, false);
                enableAllButtons();
            }
        }

        async function checkout() {
            const button = event.currentTarget;
            try {
                setLoading(button, true);
                disableAllButtons();

                const response = await fetch('/api/orders/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        product_ids: Array.from(document.querySelectorAll('.cart-item'))
                            .map(item => item.dataset.id),
                        payment_method: 'cash'
                    })
                });
                
                if (response.ok) {
                    window.location.href = '/orders/history';
                } else {
                    const error = await response.json();
                    alert(error.message || 'Failed to create order');
                }
            } catch (error) {
                console.error('Error creating order:', error);
                alert('Failed to create order');
            } finally {
                setLoading(button, false);
                enableAllButtons();
            }
        }
    </script>
</body>
</html>