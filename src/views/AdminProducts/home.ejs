<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Gán sự kiện click cho nút Export
            document.getElementById("exportBtn").addEventListener("click", exportProducts);
        });

        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll(".delete-btn").forEach(button => {
                button.addEventListener("click", function () {
                    const productId = this.getAttribute("data-id");
                    deleteProduct(productId);
                });
            });
        });

        async function deleteProduct(productId) {
            console.log("Delete button clicked for product:", productId);
            if (confirm("Are you sure you want to delete this product?")) {
                try {
                    const response = await fetch(`/api/products/delete/${productId}`, {
                        method: "DELETE",
                    });

                    if (response.ok) {
                        alert("Product deleted successfully");
                        window.location.reload();
                    } else {
                        alert("Error deleting product");
                    }
                } catch (error) {
                    console.error("Error deleting product:", error);
                    alert("Error deleting product");
                }
            }
        }


        async function exportProducts() {
            try {
                const response = await fetch('/api/products/export', {
                    method: 'GET',
                });

                if (response.ok) {
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = 'products.xlsx';
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                } else {
                    alert('Error exporting products');
                }
            } catch (error) {
                alert('Error exporting products');
            }
        }
    </script>
</head>

<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="bg-dark text-white p-3" style="width: 250px; height: 100vh;">
            <h4>VISHWEB DESIGN</h4>
            <ul class="nav flex-column">
                <li class="nav-item"><a href="/api/products" class="nav-link text-white">Dashboard</a></li>
                <li class="nav-item"><a href="/api/products/users" class="nav-link text-white">List Users</a></li>
                <li class="nav-item"><a href="#" class="nav-link text-white">Widgets</a></li>

            </ul>
        </div>

        <!-- Main Content -->
        <div class="flex-grow-1">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
                <form class="d-flex" method="GET" action="/api/products">
                    <input class="form-control me-2" type="search" name="search" placeholder="Search"
                        aria-label="Search" value="<%= searchQuery %>" style="width: 250px;">
                    <button class="btn btn-outline-light" type="submit">GO</button>
                </form>

            </nav>

            <div class="container mt-4">
                <div class="d-flex justify-content-between">
                    <h3>Manage Products</h3>
                    <div>
                        <a href="/api/products/add" class="btn btn-success">+ Add New Product</a>

                        <button id="exportBtn" class="btn btn-primary">Export</button>

                    </div>
                </div>

                <table class="table table-striped mt-3">
                    <thead class="table-dark">
                        <tr>

                            <th>Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Category</th>
                            <th>Image</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(product=> { %>
                            <tr>

                                <td>
                                    <%= product.name %>
                                </td>
                                <td>
                                    <%= product.description %>
                                </td>
                                <td>
                                    <%= product.price %>
                                </td>
                                <td>
                                    <%= product.stock %>
                                </td>
                                <td>
                                    <%= product.category %>
                                </td>
                                <td><img src="<%= product.image %>" alt="<%= product.name %>"
                                        style="width: 50px; height: 50px;" /></td>
                                <td>
                                    <a href="/api/products/edit/<%= product._id %>" class="btn btn-sm btn-primary">✎
                                        Edit</a>
                                    <button class="btn btn-sm btn-danger delete-btn" data-id="<%= product._id %>">🗑
                                        Delete</button>

                                    <a href="/api/products/view/<%= product._id %>" class="btn btn-sm btn-info">View</a>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>

                <nav>
                    <ul class="pagination justify-content-end">
                        <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= page - 1 %>&search=<%= searchQuery %>">Previous</a>
                        </li>
                        <% for(let i=1; i <=totalPages; i++) { %>
                            <li class="page-item <%= page === i ? 'active' : '' %>">
                                <a class="page-link" href="?page=<%= i %>&search=<%= searchQuery %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>
                                <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= page + 1 %>&search=<%= searchQuery %>">Next</a>
                                </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</body>

</html>