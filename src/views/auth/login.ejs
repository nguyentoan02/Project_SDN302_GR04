<!DOCTYPE html>
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panda Auth Form | Coding Vibess</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/panda.css" />
  </head>
  <body>
    <div class="container">
      <!-- Message Display -->
      <div id="message" class="thought-bubble" style="display: none"></div>

      <!-- Login Form -->
      <form
        id="loginForm"
        action="<%= typeof apiUrl !== 'undefined' ? apiUrl + '/auth/login' : '/api/auth/login' %>?redirect=<%= redirect %>"
        class="auth-section"
      >
        <div id="loginSection">
          <label for="loginUsername">Email</label>
          <input
            type="text"
            id="loginUsername"
            name="loginUsername"
            placeholder="Enter Email"
            required
          /><br />
          <label for="loginPassword">Password</label>
          <div class="password-container">
            <input
              type="password"
              id="loginPassword"
              name="loginPassword"
              placeholder="Password"
              required
            />
            <span id="toggleLoginPassword" class="toggle-password">👁️</span>
          </div>
          <button type="submit" id="loginSubmit">Login</button>
          <p class="toggle-link">
            Don't have an account? <a href="#" id="showRegister">Register</a>
          </p>
        </div>
      </form>

      <!-- Register Form -->
      <form id="registerForm" class="auth-section" style="display: none">
        <div id="registerSection">
          <label for="registerUsername">Username</label>
          <input
            type="text"
            id="registerUsername"
            name="registerUsername"
            placeholder="Enter username"
            required
          /><br />
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="Enter email" required /><br />
          <label for="registerPassword">Password</label>
          <div class="password-container">
            <input
              type="password"
              id="registerPassword"
              name="registerPassword"
              placeholder="Password"
              required
            />
            <span id="toggleRegisterPassword" class="toggle-password">👁️</span>
          </div>
          <label for="confirmPassword">Confirm Password</label>
          <div class="password-container">
            <input
              type="password"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Confirm Password"
              required
            />
            <span id="toggleConfirmPassword" class="toggle-password">👁️</span>
          </div>
          <button type="submit" id="registerSubmit">Register</button>
          <p class="toggle-link">Already have an account? <a href="#" id="showLogin">Login</a></p>
        </div>
      </form>

      <div class="ear-l"></div>
      <div class="ear-r"></div>
      <div class="panda-face">
        <div class="blush-l"></div>
        <div class="blush-r"></div>
        <div class="eye-l">
          <div class="eyeball-l"></div>
        </div>
        <div class="eye-r">
          <div class="eyeball-r"></div>
        </div>
        <div class="nose"></div>
        <div class="mouth"></div>
      </div>
      <div class="hand-l"></div>
      <div class="hand-r"></div>
      <div class="paw-l"></div>
      <div class="paw-r"></div>
    </div>

    <!-- File JS chính -->
    <script src="/js/panda.js"></script>

    <!-- Logic API login và register trong script -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');
        const usernameRef = document.getElementById('loginUsername');
        const passwordRef = document.getElementById('loginPassword');
        const registerUsernameRef = document.getElementById('registerUsername');
        const emailRef = document.getElementById('email');
        const registerPasswordRef = document.getElementById('registerPassword');
        const confirmPasswordRef = document.getElementById('confirmPassword');

        const BASE_URL = window.location.origin;
        const API_URL = '/api/auth';

        console.log({ BASE_URL, API_URL });

        // Xử lý submit login form
        loginForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          clearMessage();

          const email = usernameRef.value;
          const password = passwordRef.value;

          try {
            const response = await fetch(`${API_URL}/login`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Accept: 'application/json'
              },
              credentials: 'include',
              body: JSON.stringify({ email, password })
            });

            const data = await response.json();
            console.log(data);
            if (response.ok) {
              showMessage('Login successful!', 'success');
              normalEyeStyle();
              normalHandStyle();

              const { role } = data.data;

              console.log({ data: data.data, role });

              if (role === 'admin') {
                window.location.href = '/api/auth/dashboard';
              } else if (role === 'user') {
                window.location.href = '/api/auth/home';
              } else {
                showMessage(data?.message || 'Login failed', 'error');
                errorStyle();
              }
            } else {
              showMessage(data?.message || 'Login failed', 'error');
              errorStyle();
              // window.location.href = '/api/auth';
            }
          } catch (error) {
            showMessage(error?.message || 'Something went wrong. Please try again.', 'error');
            errorStyle();
            console.error('Login error:', error.message);
          }
        });

        // Xử lý submit register form
        registerForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          clearMessage();

          const username = registerUsernameRef.value;
          const email = emailRef.value;
          const password = registerPasswordRef.value;
          const confirmPassword = confirmPasswordRef.value;

          if (password !== confirmPassword) {
            showMessage('Passwords do not match', 'error');
            errorStyle();
            return;
          }

          try {
            const response = await fetch(`${API_URL}/register`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Accept: 'application/json'
              },
              body: JSON.stringify({ username, email, password })
            });

            const data = await response.json();
            if (response.ok) {
              showMessage('Registration successful! Please login.', 'success');
              normalEyeStyle();
              normalHandStyle();

              // Đặt email vừa đăng ký vào ô loginUsername trước khi chuyển form
              usernameRef.value = email;

              setTimeout(() => {
                loginForm.style.display = 'block';
                registerForm.style.display = 'none';
                registerForm.reset();
                // Focus vào ô password để người dùng có thể nhập ngay
                passwordRef.focus();
              }, 1000);
            } else {
              showMessage(data.message || 'Registration failed', 'error');
              errorStyle();
            }
          } catch (error) {
            showMessage('Something went wrong. Please try again.', 'error');
            errorStyle();
          }
        });
      });
    </script>
  </body>
</html>
