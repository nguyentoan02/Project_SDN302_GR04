<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hồ sơ người dùng</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: Arial, sans-serif;
        }
        .container {
            max-width: 800px;
            margin-top: 50px;
        }
        .profile-card {
            background-color: #fff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }
        .profile-card h1 {
            font-size: 2rem;
            color: #333;
            margin-bottom: 20px;
        }
        .profile-info p {
            font-size: 1.1rem;
            color: #666;
            margin-bottom: 10px;
        }
        .profile-info strong {
            color: #333;
        }
        .avatar-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 20px;
        }
        .btn-edit {
            background-color: #007bff;
            color: #fff;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: bold;
            border: none;
        }
        .btn-edit:hover {
            background-color: #0056b3;
        }
        .btn-logout {
            background-color: #dc3545;
            color: #fff;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: bold;
            border: none;
        }
        .btn-logout:hover {
            background-color: #c82333;
        }
        .modal-content {
            border-radius: 10px;
        }
        .modal-header {
            background-color: #007bff;
            color: #fff;
            border-radius: 10px 10px 0 0;
        }
        .form-label {
            font-weight: bold;
            color: #333;
        }
        .form-control {
            border-radius: 5px;
        }
        .btn-save {
            background-color: #007bff;
            color: #fff;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: bold;
            border: none;
        }
        .btn-save:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="profile-card">
            <h1>Hồ sơ của <%= user.username %></h1>
            <img src="<%= user.avatar %>" alt="Avatar" class="avatar-img">
            <div class="profile-info">
                <p><strong>Họ và tên:</strong> <%= user.fullname %></p>
                <p><strong>Tên người dùng:</strong> <%= user.username %></p>
                <p><strong>Email:</strong> <%= user.email %></p>
                <p><strong>Địa chỉ:</strong> <%= user.address || 'Chưa cập nhật' %></p>
                <p><strong>Ngày sinh:</strong> <%= user.dateOfBirth ? new Date(user.dateOfBirth).toLocaleDateString('vi-VN') : 'Chưa cập nhật' %></p>
                <p><strong>Giới tính:</strong> <%= user.gender === 'male' ? 'Nam' : user.gender === 'female' ? 'Nữ' : 'Khác' %></p>
                <p><strong>Vai trò:</strong> <%= user.role %></p>
            </div>
            <div class="d-flex gap-3 mt-4">
                <button class="btn-edit" data-bs-toggle="modal" data-bs-target="#editProfileModal">Chỉnh sửa hồ sơ</button>
                <a href="/auth/logout" class="btn-logout">Đăng xuất</a>
            </div>
        </div>
    </div>

    <!-- Modal chỉnh sửa hồ sơ -->
    <div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editProfileModalLabel">Chỉnh sửa hồ sơ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="editProfileForm">
                        <div class="mb-3">
                            <label for="fullname" class="form-label">Họ và tên</label>
                            <input type="text" class="form-control" id="fullname" name="fullname" value="<%= user.fullname %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="address" class="form-label">Địa chỉ</label>
                            <input type="text" class="form-control" id="address" name="address" value="<%= user.address || '' %>">
                        </div>
                        <div class="mb-3">
                            <label for="dateOfBirth" class="form-label">Ngày sinh</label>
                            <input type="date" class="form-control" id="dateOfBirth" name="dateOfBirth" value="<%= user.dateOfBirth ? user.dateOfBirth.toISOString().split('T')[0] : '' %>">
                        </div>
                        <div class="mb-3">
                            <label for="gender" class="form-label">Giới tính</label>
                            <select class="form-control" id="gender" name="gender">
                                <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Nam</option>
                                <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Nữ</option>
                                <option value="other" <%= user.gender === 'other' ? 'selected' : '' %>>Khác</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="avatar" class="form-label">URL ảnh đại diện</label>
                            <input type="url" class="form-control" id="avatar" name="avatar" value="<%= user.avatar %>">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn-save" id="saveProfileChanges">Lưu thay đổi</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('saveProfileChanges').addEventListener('click', function(e) {
            e.preventDefault();
            const form = document.getElementById('editProfileForm');
            const formData = new FormData(form);

            fetch('/api/auth/profile', {
                method: 'PUT',
                body: JSON.stringify({
                    fullname: formData.get('fullname'),
                    address: formData.get('address'),
                    dateOfBirth: formData.get('dateOfBirth'),
                    gender: formData.get('gender'),
                    avatar: formData.get('avatar')
                }),
                headers: {
                    'Content-Type': 'application/json'
                },
                credentials: 'include' // Gửi cookie chứa token
            })
            .then(response => response.json())
            .then(data => {
                if (data.message === 'Success') {
                    alert('Hồ sơ đã được cập nhật thành công!');
                    window.location.reload(); // Tải lại trang để hiển thị thông tin mới
                } else {
                    alert('Lỗi: ' + (data.message || 'Không thể cập nhật hồ sơ'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Lỗi cập nhật hồ sơ: ' + error.message);
            });
        });
    </script>
</body>
</html>