<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tìm kiếm sách</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #e6f3ff; 
            font-family: Arial, sans-serif;
        }
        
        .search-container {
    display: flex;
    align-items: center;
    border-radius: 50px;
    padding: 5px; 
    width: 100%;
    max-width: 700px;
    background-color: #fff; 
    border: 1px solid #ccc; 
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1); 
    margin-top: -20px;
}

.search-container input {
    flex: 1;
    border: none;
    outline: none;
    padding: 10px 15px;
    border-radius: 50px;
    background: transparent;
    color: #333; 
    font-size: 18px; 
}

.search-container input::placeholder {
    color: #999; 
}

.search-container button {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 24px; 
    color: #666; 
    padding: 0 15px; 
    transition: color 0.3s ease-in-out; 
}

.search-container button:hover {
    color: #28a745; 
}

        /* Book List */
        .book-list {
            list-style: none;
            padding: 0;
            margin-top: 20px;
            max-width: 700px; 
            margin-left: auto;
            margin-right: auto;
        }
        
        .book-item {
            display: flex;
            align-items: center;
            padding: 10px; 
            border-radius: 8px;    
            margin-bottom: 10px; 
            gap: 10px; 
        }
        
        .book-item img {
            width: 60px;
            height: 80px; 
            object-fit: cover;
            border-radius: 4px; 
        }
        
        .book-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 2px; 
        }
        
        .book-name a{
            font-size: 16px;
            font-weight: bold;
            color: #333; 
            margin: 0;
            text-decoration: none; 
        }
        
        .book-author {
            font-size: 12px; 
            color: #666; 
            margin: 0; 
        }
        
        .book-price {
            color: #ff0000;
            font-weight: bold;
            font-size: 16px; 
            margin: 0; 
        }

        .book-stock {
            font-size: 14px;
            color: #8d5e2a; 
            font-weight: 400;

        }

        .book-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .add-to-cart {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 10px 10px;
            border-radius: 15px;
            cursor: pointer;
            font-size: 14px; 
        }
        
        .add-to-cart:hover {
            background-color: #218838;
        }
        
        .add-to-cart:disabled {
            background-color: #6c757d; 
            cursor: not-allowed;
        }

        .no-results {
            text-align: center;
            color: #dc3545; 
            font-size: 16px;
            margin-top: 20px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .search-container {
                padding: 8px 15px; 
                max-width: 90%; 
            }

            .book-list {
                max-width: 90%;
            }

            .book-item {
                flex-direction: column;
                text-align: center;
                padding: 10px;
                gap: 5px; 
            }

            .book-item img {
                width: 50px;
                height: 70px;
            }

            .book-name {
                font-size: 14px;
            }

            .book-author, .book-price, .book-stock {
                font-size: 10px;
            }

            .add-to-cart {
                font-size: 10px;
                padding: 4px 8px;
            }
        }

        @media (max-width: 576px) {
            .book-item img {
                width: 40px;
                height: 60px;
            }

            .book-name {
                font-size: 12px;
            }

            .book-author, .book-price, .book-stock {
                font-size: 10px;
            }

            .add-to-cart {
                font-size: 10px;
                padding: 3px 6px;
            }
        }
    </style>
</head>
<body >

    <div class="container mt-5">
        <form action="/api/books/filter" method="GET" class="d-flex justify-content-center">
            <div class="search-container">
                <input type="text" id="name" name="name" placeholder="Nhập tên sách để tìm kiếm." value="<%= name || '' %>">
                <button type="submit">🔍</button>
            </div>
        </form>
    
        <% if (name && books.length > 0) { %>
            <ul class="book-list">
                <% books.forEach(book => { %>
                    <li class="book-item">
                      <a href="/api/books/<%= book.slug %>">
                        <img src="<%= book.image %>" alt="<%= book.name %>">
                    </a>
                        <div class="book-info">
                          <span class="book-name">
                            <a href="/api/books/<%= book.slug %>"><%= book.name %></a>
                          </span>
                          <span class="book-author">Tác giả: <%= book.author %></span>
                        </div>
                        <span class="book-price"><%= new Intl.NumberFormat('vi-VN').format(book.price) %>đ</span>
                        <span class="book-stock"><%= book.stock > 0 ? 'In Stock' : 'Out of Stock' %></span>
                        <div class="book-actions">
                            <button class="add-to-cart" <%= book.stock === 0 ? 'disabled' : '' %>>Thêm vào giỏ</button>
                        </div>
                    </li>
                <% }) %>
            </ul>
        <% } else if (name) { %>
            <p class="no-results">❌ Không tìm thấy sách nào phù hợp.</p>
        <% } else { %>
            <p class="text-muted text-center mt-4"></p>
        <% } %>
    </div>


    <script>
      document.addEventListener("DOMContentLoaded", function () {
          const form = document.querySelector("form");
          const input = document.querySelector("#name");
  
          form.addEventListener("submit", function (event) {
              if (!input.value.trim()) {
                  event.preventDefault(); 
                  
                  let errorMsg = document.getElementById("error-message");
                  if (!errorMsg) {
                      errorMsg = document.createElement("p");
                      errorMsg.id = "error-message";
                      errorMsg.className = "no-results";
                      errorMsg.textContent = "⚠️ Vui lòng nhập từ khóa để tìm kiếm!";
                                            form.parentNode.insertBefore(errorMsg, form.nextSibling);
                  }
              }
          });
  
          input.addEventListener("input", function () {
              const errorMsg = document.getElementById("error-message");
              if (errorMsg) {
                  errorMsg.remove();
              }
          });
      });
  </script>
  
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
</body>
</html>