<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách sách</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            font-size: 1.1rem;
        }

        .carousel-container {
            overflow: hidden;
            position: relative;
            max-width: 100%;
        }

        .carousel-track {
            display: flex;
            transition: transform 0.5s ease-in-out;
        }

        .book-card {
            border-radius: 10px;
            border: none;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            width: 260px;
            margin: 10px;
            flex-shrink: 0;
            background-color: #fff;
            text-align: center;
            transition: transform 0.3s ease-in-out;
            padding-bottom: 15px;
        }

        .book-card:hover {
            transform: scale(1.05);
        }

        .book-card img {
            height: 310px;
            width: 100%;
            object-fit: cover;
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
        }

        .carousel-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background-color: rgba(0, 0, 0, 0.5);
            color: white;
            border: none;
            padding: 10px;
            cursor: pointer;
            z-index: 2;
            border-radius: 50%;
        }

        .carousel-btn:hover {
            background-color: rgba(0, 0, 0, 0.8);
        }

        .prev {
            left: 15px;
        }

        .next {
            right: 15px;
        }

        .buy-btn {
            display: block;
            width: 85%;
            margin: 10px auto;
            background-color: #498374;
            color: white;
            border: none;
            padding: 12px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 25px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .buy-btn:hover {
            background-color: #cc0000;
        }

        .wishlist-btn {
            display: none;
            position: absolute;
            top: 150px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #ffc6c5;
            color: #000;
            border: none;
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 20px;
            cursor: pointer;
            z-index: 1;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .book-card:hover .wishlist-btn {
            display: block;
        }

        .wishlist-btn:hover {
            background-color: #eb6262;
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-top: 10px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .price {
            font-size: 1.1rem;
            font-weight: bold;
            color: red;
            margin-bottom: 10px;
            margin-top: 10px;
        }
    </style>
</head>
<body class="container mt-4">

    <h1 class="mb-4 text-center">📚 Danh Sách Sách</h1>

    <div class="carousel-container">
        <button class="carousel-btn prev">❮</button>
        <div class="carousel-track" id="bookCarousel">
            <% books.forEach((book) => { %>
                <div class="book-card">
                    <a href="/api/books/<%= book.slug %>">
                        <img src="<%= book.image %>" alt="<%= book.name %>">
                    </a>
                    <button class="wishlist-btn" data-product-id="<%= book._id %>">♥ Thêm vào yêu thích</button>
                    <div class="card-body">
                        <a href="/api/books/<%= book.slug %>" class="text-decoration-none text-dark">
                            <h6 class="card-title"><%= book.name %></h6>
                        </a>
                        <p class="price"><%= new Intl.NumberFormat('vi-VN').format(book.price) %>đ</p>
                        <button class="buy-btn">Mua ngay</button>
                    </div>
                </div>
            <% }); %>
        </div>
        <button class="carousel-btn next">❯</button>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const track = document.getElementById("bookCarousel");
            const prev = document.querySelector(".prev");
            const next = document.querySelector(".next");
            const books = document.querySelectorAll(".book-card");
            const bookWidth = books[0].offsetWidth + 15;
            let index = 0;
            let autoScroll;
    
            function updateCarousel() {
                track.style.transform = `translateX(-${index * bookWidth}px)`;
            }
    
            function nextSlide() {
                if (index < books.length - 5) {
                    index++;
                } else {
                    index = 0; 
                }
                updateCarousel();
            }
    
            function prevSlide() {
                if (index > 0) {
                    index--;
                } else {
                    index = books.length - 5;
                }
                updateCarousel();
            }
    
            next.addEventListener("click", () => {
                clearInterval(autoScroll);
                nextSlide();
                startAutoScroll();
            });
    
            prev.addEventListener("click", () => {
                clearInterval(autoScroll);
                prevSlide();
                startAutoScroll();
            });
    
            function startAutoScroll() {
                autoScroll = setInterval(nextSlide, 3000);
            }
    
            startAutoScroll();

            // Add to Wishlist functionality
            $('.wishlist-btn').on('click', function(event) {
                const productId = $(this).data('product-id');
                $.ajax({
                    url: `/api/favorites/${productId}`,
                    method: 'POST',
                    success: function(response) {
                        alert(response.message);
                        $(event.target).hide(); 
                    },
                    error: function(error) {
                        alert('Có lỗi xảy ra khi thêm vào danh sách yêu thích: ' + error.responseJSON?.message || 'Unknown error');
                    }
                });
            });
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
</body>
</html>