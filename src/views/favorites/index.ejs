<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách yêu thích</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .wishlist-table {
            width: 100%;
            border-collapse: collapse;
        }
        .wishlist-table th, .wishlist-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }
        .wishlist-table th {
            font-weight: bold;
        }
        .wishlist-table img {
            width: 60px;
            height: 80px;
            object-fit: cover;
        }
        .remove-btn {
            background-color: transparent;
            border: none;
            cursor: pointer;
            color: red;
            font-size: 18px;
        }
        .add-to-cart {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
        }
        .add-to-cart:hover {
            background-color: #218838;
        }
    </style>
</head>
<body class="container mt-4">
    <h1 class="text-center">❤️ Danh sách yêu thích</h1>
    
    <div class="mb-4">
        <a href="/api/books" class="btn btn-secondary">⬅ Quay lại danh sách sách</a>
    </div>

    <% if (products.length === 0) { %>
        <p class="text-center">Danh sách yêu thích của bạn đang trống.</p>
    <% } else { %>
        <table class="wishlist-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Sách</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach((product) => { %>
                    <tr>
                        <td><img src="<%= product.image %>" alt="<%= product.name %>"></td>
                        <td>
                            <strong><%= product.name %></strong><br>
                            <small>Tác giả: <%= product.author %></small>
                        </td>
                        <td class="text-danger"><%= new Intl.NumberFormat('vi-VN').format(product.price) %>đ</td>
                        <td>
                            <%= product.stock > 0 ? 'In Stock' : 'Out of Stock' %>
                        </td>
                        <td>
                            <button class="remove-btn" data-product-id="<%= product._id %>">🗑</button>
                            <button class="add-to-cart" <%= product.stock === 0 ? 'disabled' : '' %>>Thêm vào giỏ</button>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
    <script>
       $('.remove-btn').on('click', function() {
           const productId = $(this).data('product-id');
           $.ajax({
               url: `/api/favorites/${productId}`,
               method: 'DELETE',
               success: function(response) {
                   alert(response.message);
                   location.reload();
               },
               error: function(error) {
                   alert('Có lỗi xảy ra khi xóa khỏi danh sách yêu thích');
               }
           });
       });
    </script>
</body>
</html>
