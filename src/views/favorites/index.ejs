<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách yêu thích</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .wishlist-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px 15px;
        }

        .wishlist-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .wishlist-table th, 
        .wishlist-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .wishlist-table th {
            font-weight: bold;
            background-color: #f8f9fa;
        }

        .wishlist-table img {
            width: 60px;
            height: 80px;
            object-fit: cover;
            border-radius: 5px;
        }

        .wishlist-table .remove-btn {
            background-color: transparent;
            border: none;
            cursor: pointer;
            color: #dc3545;
            font-size: 18px;
            transition: color 0.3s ease;
        }

        .wishlist-table .remove-btn:hover {
            color: #b02a37;
        }

        .wishlist-table .add-to-cart {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .wishlist-table .add-to-cart:hover {
            background-color: #218838;
        }

        .wishlist-table .add-to-cart:disabled {
            background-color: #6c757d;
            cursor: not-allowed;
        }

        .wishlist-empty {
            text-align: center;
            color: #6c757d;
            padding: 20px;
        }

        /* Back button */
        .back-to-home {
            margin-bottom: 20px;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .wishlist-table th, 
            .wishlist-table td {
                padding: 10px;
            }

            .wishlist-table img {
                width: 50px;
                height: 70px;
            }

            .wishlist-table .add-to-cart {
                padding: 4px 8px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <!-- Include navbar -->
    <%- include('../partials/navbar') %>

    <!-- Wishlist content -->
    <div class="wishlist-wrapper">
        <h1 class="text-center mb-4">❤️ Danh sách yêu thích</h1>
        
        <% if (products.length === 0) { %>
            <p class="wishlist-empty">Danh sách yêu thích của bạn đang trống.</p>
        <% } else { %>
            <table class="wishlist-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Sách</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach((product) => { %>
                        <tr>
                            <td><img src="<%= product.image %>" alt="<%= product.name %>"></td>
                            <td>
                                <strong><%= product.name %></strong><br>
                                <small>Tác giả: <%= product.author %></small>
                            </td>
                            <td class="text-danger"><%= new Intl.NumberFormat('vi-VN').format(product.price) %>đ</td>
                            <td>
                                <%= product.stock > 0 ? 'In Stock' : 'Out of Stock' %>
                            </td>
                            <td>
                                <button class="remove-btn" data-product-id="<%= product._id %>">🗑</button>
                                <!-- <button class="add-to-cart" <%= product.stock === 0 ? 'disabled' : '' %>>Thêm vào giỏ</button> -->
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </div>

    <!-- Include footer -->
    <%- include('../partials/footerHome') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>
    <script>
        $('.remove-btn').on('click', function() {
            const productId = $(this).data('product-id');
            $.ajax({
                url: `/api/favorites/${productId}`,
                method: 'DELETE',
                success: function(response) {
                    alert(response.message);
                    location.reload();
                },
                error: function(error) {
                    alert('Có lỗi xảy ra khi xóa khỏi danh sách yêu thích');
                }
            });
        });
    </script>
</body>
</html>